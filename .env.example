# Server-side only — used for SSR/ISR Strapi fetches (never exposed to the browser)
# Set as Kubernetes secrets / GitHub Actions secrets
STRAPI_API_URL=http://strapi-cms.development.svc.cluster.local:1337
STRAPI_API_TOKEN=<read-only token from Strapi admin → Settings → API Tokens>

# Client-safe — prepended to relative media URLs and used for contact form POST
# Safe to commit as a non-secret env var; passed as a Docker build-arg in CI
NEXT_PUBLIC_STRAPI_URL=https://strapi.yourdomain.com

# Google Sheets — contact form submissions
GOOGLE_SHEET_ID=<spreadsheet ID from the Google Sheet URL>
GOOGLE_SERVICE_ACCOUNT_KEY=<full JSON contents of the service account key file>
